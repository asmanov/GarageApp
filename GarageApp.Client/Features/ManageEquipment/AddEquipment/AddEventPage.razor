@page "/add-event"
@inject DatabaseService DatabaseService
@inject ISnackbar Snackbar

<PageTitle>Add event</PageTitle>

<MudBreadcrumbs Items="_items" Separator=">"></MudBreadcrumbs>

<EventForm @ref="_eventItem" OnSubmit="SubmitNewEvent" />

@code {
    private readonly List<BreadcrumbItem> _items =
                    [
        new("Home", href: "/GarageApp/", icon: Icons.Material.Filled.Home),
        new("Add event", href: null, disabled: true, icon: Icons.Material.Filled.Create)
    ];

    private EventForm _eventItem = default!;

    private async Task SubmitNewEvent(Events item)
    {
        var response = await DatabaseService.Insert<Events>(item);

        if (response == null)
        {
            Snackbar.Add("Ошибка при добавлении записи");
            StateHasChanged();
            return;
        }

        Snackbar.Add("Запись успешно добавлена");
        _eventItem.ResetForm();
        StateHasChanged();
    }
}
